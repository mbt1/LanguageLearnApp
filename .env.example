# LanguageLearn — Production environment variables
# Copy this file to .env and fill in all values before running docker compose.

# ── Domain ────────────────────────────────────────────────────────────────────
# The public domain name Caddy will serve and obtain a TLS certificate for.
DOMAIN=yourdomain.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=languagelearn
POSTGRES_USER=languagelearn
POSTGRES_PASSWORD=changeme-use-a-long-random-string

# Connection URL used by the server (points to the 'db' service inside compose).
DATABASE_URL=postgresql://languagelearn:changeme-use-a-long-random-string@db:5432/languagelearn

# ── Server authentication ─────────────────────────────────────────────────────
# Must be a long random string. Generate with: openssl rand -hex 32
JWT_SECRET=changeme-use-a-long-random-string

# Token lifetimes (optional — defaults shown)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── WebAuthn (passkeys) ───────────────────────────────────────────────────────
WEBAUTHN_RP_ID=yourdomain.com
WEBAUTHN_RP_NAME=LanguageLearn
WEBAUTHN_RP_ORIGIN=https://yourdomain.com

# ── Backup (S3 optional) ──────────────────────────────────────────────────────
# Leave S3_BUCKET empty to store backups in the Docker volume only.
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
